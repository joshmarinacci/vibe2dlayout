{
  "name": "vibe2dlayout",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "clean": "rm -rf dist",
    "check": "tsc",
    "preview": "vite preview",
    "publish-build": "VITE_BASE_PATH=/draw/ vite build",
    "publish-upload": "scp -r -i ../../WebstormProjects/deployman_private.key dist/** deployman@apps.josh.earth:/sites/apps.josh.earth/draw/",
    "publish-full": "npm run clean && npm run publish-build && npm run publish-upload",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "opentype.js": "^1.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "roughjs": "^4.6.6",
    "woff2-encoder": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vitest": "^2.1.8"
  }
}
